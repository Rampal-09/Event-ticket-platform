// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  TENANT
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TicketStatus {
  UNUSED
  USED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id              Int            @id @default(autoincrement())
  name            String
  email           String         @unique
  password        String
  role            Role           @default(TENANT)
  status          UserStatus     @default(ACTIVE)
  organizedEvents Event[]        @relation("OrganizerEvents")
  reviewedEvents  Event[]        @relation("ReviewerEvents")
  refreshTokens   RefreshToken[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Event {
  id           Int      @id @default(autoincrement())
  title        String
  category     String
  description  String   @db.Text
  location     String
  eventDate    DateTime
  ticketPrice  Float
  totalTickets Int
  ticketsSold  Int      @default(0)
  image        String?

  organizerId Int
  organizer   User @relation("OrganizerEvents", fields: [organizerId], references: [id])

  reviewedById    Int?
  reviewedBy      User?   @relation("ReviewerEvents", fields: [reviewedById], references: [id])
  rejectionReason String? @db.Text

  status               EventStatus @default(PENDING)
  isPublic             Boolean     @default(true)
  sellingFastThreshold Int         @default(20)

  // Using JSON fields for simple string arrays
  tags       Json? // ["Outdoor", "Music"]
  highlights Json? // ["3 Live Stages", "Food Village"]

  galleryImages EventImage[]
  schedule      EventSchedule[]
  promoCodes    PromoCode[]
  tickets       Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventImage {
  id           Int      @id @default(autoincrement())
  eventId      Int
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model EventSchedule {
  id         Int    @id @default(autoincrement())
  eventId    Int
  event      Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time       String
  act        String
  orderIndex Int    @default(0)
}

model PromoCode {
  id            Int          @id @default(autoincrement())
  eventId       Int
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  code          String
  discountType  DiscountType
  discountValue Float
  maxUsage      Int          @default(0)
  currentUsage  Int          @default(0)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  @@unique([eventId, code])
}

model Ticket {
  id          Int          @id @default(autoincrement())
  eventId     Int
  event       Event        @relation(fields: [eventId], references: [id])
  buyerName   String
  buyerEmail  String
  qrPayload   String       @unique
  status      TicketStatus @default(UNUSED)
  purchasedAt DateTime     @default(now())
}
